<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Needed for streaming from the sunoh-api. -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- audio_service: background playback + foreground media notification. -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- Chromecast / Google Cast discovery. The flutter_chrome_cast
         plugin ships an empty manifest so the host app declares these:
           * ACCESS_NETWORK_STATE / ACCESS_WIFI_STATE — query the active
             SSID + connectivity state, used by the Cast SDK to filter
             discoverable devices to the local network.
           * CHANGE_WIFI_MULTICAST_STATE — subscribe to mDNS multicast
             packets (the protocol Cast uses to advertise devices on the
             LAN). Without this the SDK silently never sees any device.
           * NEARBY_WIFI_DEVICES — Android 13+ runtime permission for
             scanning nearby Wi-Fi devices. Marked `neverForLocation` so
             the system doesn't also prompt for fine-location (we don't
             need it for Cast). -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE"/>
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE"/>
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="33"/>
    <application
        android:label="sunoh"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Deep links: custom scheme (always app-internal, no domain
                 verification needed) — sunoh://album/<id>, sunoh://song/<id>,
                 sunoh://search?q=…, sunoh://share/<id> etc. Handled by
                 lib/router/deep_links.dart. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="sunoh"/>
            </intent-filter>
            <!-- App Links: https://sunoh.online/* — autoVerify=true so
                 Android skips the chooser when the assetlinks.json at
                 https://sunoh.online/.well-known/assetlinks.json is reachable
                 and lists this package + signing fingerprint. Until then the
                 user sees a "open with…" sheet but the wiring still works. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https" android:host="sunoh.online"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- Google Cast SDK requires the consuming app to declare the
             OptionsProvider class. flutter_chrome_cast's plugin manifest
             is empty, so we point at its provider here. WITHOUT this the
             Cast SDK initialises with an empty provider, discovery
             silently never starts, and the device picker stays empty
             even on a fully Cast-capable LAN. -->
        <meta-data
            android:name="com.google.android.gms.cast.framework.OPTIONS_PROVIDER_CLASS_NAME"
            android:value="com.felnanuke.google_cast.GoogleCastOptionsProvider"/>

        <!-- Cast SDK posts a media-style notification while a session
             is active so the user can pause/skip from the lockscreen
             without re-opening the app. -->
        <service
            android:name="com.google.android.gms.cast.framework.media.MediaNotificationService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback"/>

        <!-- audio_service plumbing — foreground media service + hardware
             media-button receiver (headset play/pause). -->
        <service
            android:name="com.ryanheise.audioservice.AudioService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="true"
            tools:ignore="Instantiatable">
            <intent-filter>
                <action android:name="android.media.browse.MediaBrowserService"/>
            </intent-filter>
        </service>
        <receiver
            android:name="com.ryanheise.audioservice.MediaButtonReceiver"
            android:exported="true"
            tools:ignore="Instantiatable">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON"/>
            </intent-filter>
        </receiver>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- url_launcher needs explicit query intents on Android 11+ for
             non-https schemes. UPI for the Support sunoh. tip flow,
             https for the Buy Me A Coffee fallback. -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="upi"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
    </queries>
</manifest>
